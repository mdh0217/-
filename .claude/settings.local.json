{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git config:*)",
      "Bash(git commit -m 'chore: ECC 초기 설정 완료 \\(P0~P1\\):*)",
      "Bash(bun install:*)",
      "Bash(npm install:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/run-with-flags.js pre-compact scripts/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/run-with-flags.js post-edit-lint scripts/hooks/post-edit-lint.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/run-with-flags.js stop scripts/hooks/stop.js"
          }
        ]
      }
    ]
  }
}
