# ─────────────────────────────────────────────
# ECC 환경 변수 예시
# 이 파일을 .env 로 복사하고 값을 채워서 사용하세요.
# .env 파일은 절대 커밋하지 마세요.
# ─────────────────────────────────────────────

# GitHub MCP 서버용 토큰
GITHUB_TOKEN=

# Exa 검색 MCP 서버 API 키
EXA_API_KEY=

# ECC 훅 프로파일 (light | full | off)
ECC_HOOK_PROFILE=full

# 비활성화할 훅 이름 (콤마 구분, 선택사항)
# 예: ECC_DISABLED_HOOKS=session-start,pre-compact
ECC_DISABLED_HOOKS=
