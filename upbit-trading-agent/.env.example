# ============================================================
# 업비트 API 자격증명 (절대 .env 파일을 Git에 커밋하지 마세요!)
# https://upbit.com/mypage/open_api_management 에서 발급
# ============================================================
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# ============================================================
# 트레이딩 설정
# ============================================================
# 운영 모드: 'live' | 'paper' (paper = 가상 주문, 실제 체결 없음)
TRADING_MODE=paper

# 1회 주문 최대 금액 (KRW)
MAX_ORDER_KRW=100000

# 동시 보유 코인 최대 수
MAX_POSITIONS=3

# ============================================================
# 전략 파라미터 (래리 윌리엄스 변동성 돌파)
# ============================================================
# 변동성 비율 (0.3 ~ 0.7 권장)
VOLATILITY_RATIO=0.5

# 대상 마켓 (쉼표로 구분)
TARGET_MARKETS=KRW-BTC,KRW-ETH,KRW-SOL

# ============================================================
# 시스템 설정
# ============================================================
# 데이터베이스 파일 경로
DB_PATH=./data/trading.db

# 로그 레벨: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# 헬스체크 포트
HEALTH_PORT=3000

# ============================================================
# 서킷 브레이커 설정
# ============================================================
# 연속 실패 허용 횟수
CIRCUIT_FAILURE_THRESHOLD=5

# 서킷 오픈 후 재시도까지 대기 시간 (ms)
CIRCUIT_RESET_TIMEOUT_MS=60000

# ============================================================
# 리스크 관리
# ============================================================
# 일일 최대 손실 허용 비율 (0.05 = 5%, KST 기준)
# 당일 총 자산이 시작 대비 이 비율 이상 손실되면 신규 매수 / DCA 차단
DAILY_LOSS_LIMIT=0.05
